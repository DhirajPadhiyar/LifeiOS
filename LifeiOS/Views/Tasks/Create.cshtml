@model LifeiOS.Models.TaskItem

@{
    ViewData["Title"] = "Create Task";
}

<div class="page-header">
    <div>
        <h2>Create Task</h2>
        <p>Add a new task to your LifeOS.</p>
    </div>
</div>

<div class="card-custom">

    <div class="card-body">

        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>

                <input asp-for="Title"
                       class="form-control-custom" />

                <span asp-validation-for="Title"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>

                <textarea asp-for="Description"
                          rows="5"
                          class="form-control-custom"></textarea>

                <span asp-validation-for="Description"
                      class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Priority" class="form-label"></label>

                <select asp-for="Priority"
                        asp-items="Html.GetEnumSelectList<TaskPriority>()"
                        class="form-select-custom">
                </select>

                <span asp-validation-for="Priority"
                      class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="DueDate" class="form-label"></label>

                <input asp-for="DueDate"
                       type="date"
                       class="form-control-custom" />

                <span asp-validation-for="DueDate"
                      class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">

                <button type="submit"
                        class="btn-custom btn-primary-custom">
                    Save Task
                </button>

                <a asp-action="Index"
                   class="btn-custom btn-secondary-custom">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}