@model LifeiOS.Models.TaskItem

@{
    ViewData["Title"] = "Delete Task";
}

<div class="page-header">
    <div>
        <h2>Delete Task</h2>
        <p>Confirm before deleting this task.</p>
    </div>
</div>

<div class="card-custom">

    <div class="card-body">

        <div class="alert alert-danger">

            <h5 class="mb-3">
                Are you sure you want to delete this task?
            </h5>

            <p class="mb-0">
                This action cannot be undone.
            </p>

        </div>

        <table class="table-custom">

            <tr>
                <th style="width:180px;">Title</th>
                <td>@Model.Title</td>
            </tr>

            <tr>
                <th>Priority</th>
                <td>@Model.Priority</td>
            </tr>

            <tr>
                <th>Due Date</th>
                <td>@(Model.DueDate?.ToString("dd MMM yyyy") ?? "-")</td>
            </tr>

            <tr>
                <th>Status</th>
                <td>@(Model.IsCompleted ? "Completed" : "Pending")</td>
            </tr>

        </table>

        <form asp-action="Delete" method="post">

            <input asp-for="Id" type="hidden" />

            <div class="d-flex gap-2 mt-4">

                <button type="submit"
                        class="btn-custom btn-danger-custom">
                    Delete Task
                </button>

                <a asp-action="Index"
                   class="btn-custom btn-secondary-custom">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>