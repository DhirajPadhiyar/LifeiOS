@model LifeiOS.ViewModels.ProfileViewModel

@{
    ViewData["Title"] = "Edit Profile";
}

<div class="page-header">
    <h2>Edit Profile</h2>
    <p>Update your account information.</p>
</div>

<div class="card-custom">

    <div class="card-body">

        <form asp-action="Edit" method="post">

            <div asp-validation-summary="ModelOnly"
                 class="text-danger mb-3">
            </div>

            <div class="mb-3">

                <label asp-for="FullName"
                       class="form-label-custom">
                </label>

                <input asp-for="FullName"
                       class="form-control-custom"
                       placeholder="Enter your full name" />

                <span asp-validation-for="FullName"
                      class="text-danger">
                </span>

            </div>

            <div class="mb-3">

                <label asp-for="Email"
                       class="form-label-custom">
                </label>

                <input asp-for="Email"
                       class="form-control-custom"
                       readonly />

            </div>

            <div class="mb-4">

                <label class="form-label-custom">
                    Member Since
                </label>

                <input value="@(Model.CreatedAt.ToString("dd MMM yyyy | hh:mm:ss tt"))"
                       class="form-control-custom"
                       readonly />

            </div>

            <div class="d-flex gap-3">

                <button type="submit"
                        class="btn-custom btn-primary-custom flex-fill">
                    Save Changes
                </button>

                <a asp-action="Index"
                   class="btn-custom btn-secondary-custom flex-fill text-center">
                    Cancel
                </a>

            </div>

        </form>

    </div>

</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}